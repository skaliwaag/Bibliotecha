@page "/"

<PageTitle>Library Management System</PageTitle>

<h1>Library Management System</h1>

<p class="lead">Welcome! Use the navigation menu to manage books, users, and borrowing.</p>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"> Manage Books</h5>
                <p class="card-text">Add, edit, delete, and list all books in the library.</p>
                <a href="books" class="btn btn-primary">Go to Books</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"> Manage Users</h5>
                <p class="card-text">Add, edit, delete, and list all registered library users.</p>
                <a href="users" class="btn btn-primary">Go to Users</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"> Borrow / Return</h5>
                <p class="card-text">Borrow a book for a user or return a previously borrowed book.</p>
                <a href="borrowing" class="btn btn-primary">Go to Borrowing</a>
            </div>
        </div>
    </div>
</div>
